<!DOCTYPE html>
<html lang="he" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Mashet Sentence Engine</title>
<link href="https://fonts.googleapis.com/css2?family=Noto+Sans+Hebrew:wght@300;400;700&family=Share+Tech+Mono&family=Cinzel:wght@400;600&display=swap" rel="stylesheet">
<style>
  :root {
    --black: #050505;
    --amber: #c8922a;
    --amber-bright: #f0b847;
    --amber-dim: #6b4e15;
    --white: #e8e4d9;
    --dim: #4a4540;
    --row-border: rgba(200,146,42,0.15);
    --glyph-size: 40px;
    --word-active: rgba(200,146,42,0.12);
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    background: var(--black);
    color: var(--white);
    font-family: 'Share Tech Mono', monospace;
    min-height: 100vh;
    overflow-x: hidden;
  }

  body::before {
    content: '';
    position: fixed; inset: 0;
    background-image:
      linear-gradient(rgba(200,146,42,0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(200,146,42,0.03) 1px, transparent 1px);
    background-size: 40px 40px;
    pointer-events: none; z-index: 0;
  }

  .container {
    position: relative; z-index: 1;
    max-width: 960px; margin: 0 auto;
    padding: 20px 12px 80px;
  }

  /* HEADER */
  .header {
    text-align: center;
    padding: 24px 0 28px;
    border-bottom: 1px solid var(--row-border);
    margin-bottom: 24px;
  }

  .header-title {
    font-family: 'Cinzel', serif;
    font-size: clamp(13px, 3.5vw, 20px);
    letter-spacing: 0.18em;
    color: var(--amber);
    text-transform: uppercase;
    margin-bottom: 6px;
  }

  .header-formula {
    font-family: 'Noto Sans Hebrew', sans-serif;
    font-size: clamp(14px, 4vw, 22px);
    color: rgba(232,228,217,0.35);
    direction: ltr;
    letter-spacing: 0.05em;
  }

  .header-formula span { color: var(--amber-bright); }

  /* SENTENCE BAR */
  .sentence-bar {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    align-items: center;
    padding: 12px 16px;
    border: 1px solid var(--row-border);
    background: rgba(10,10,15,0.6);
    margin-bottom: 20px;
    min-height: 56px;
    direction: rtl;
  }

  .sentence-bar-label {
    font-size: 9px;
    letter-spacing: 0.3em;
    color: var(--dim);
    text-transform: uppercase;
    direction: ltr;
    width: 100%;
    margin-bottom: 4px;
  }

  .word-token {
    display: flex;
    align-items: center;
    gap: 6px;
    background: rgba(200,146,42,0.08);
    border: 1px solid rgba(200,146,42,0.25);
    border-radius: 3px;
    padding: 4px 10px;
    cursor: pointer;
    transition: all 0.2s;
    direction: ltr;
  }

  .word-token:hover { border-color: var(--amber); background: rgba(200,146,42,0.15); }

  .word-token.active {
    border-color: var(--amber-bright);
    background: rgba(200,146,42,0.2);
    box-shadow: 0 0 8px rgba(200,146,42,0.25);
  }

  .word-token .tok-hebrew {
    font-family: 'Noto Sans Hebrew', sans-serif;
    font-size: 20px;
    color: var(--amber-bright);
    direction: rtl;
  }

  .word-token .tok-phonetic {
    font-size: 10px;
    color: var(--amber-dim);
    direction: ltr;
  }

  .word-token .tok-approx {
    font-size: 10px;
    color: rgba(232,228,217,0.4);
    direction: ltr;
  }

  .word-token .tok-delete {
    font-size: 10px;
    color: var(--dim);
    cursor: pointer;
    padding: 0 2px;
    margin-left: 4px;
    transition: color 0.15s;
  }

  .word-token .tok-delete:hover { color: rgba(200,80,60,0.7); }

  .word-add-btn {
    background: transparent;
    border: 1px dashed rgba(200,146,42,0.2);
    color: var(--amber-dim);
    font-family: 'Share Tech Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.2em;
    padding: 4px 12px;
    cursor: pointer;
    text-transform: uppercase;
    transition: all 0.2s;
    direction: ltr;
    border-radius: 3px;
  }

  .word-add-btn:hover { border-color: var(--amber); color: var(--amber); }

  .sentence-empty {
    font-size: 11px;
    color: var(--dim);
    letter-spacing: 0.2em;
    direction: ltr;
    font-style: italic;
  }

  /* ACTIVE WORD BUILDER */
  .word-builder {
    border: 1px solid rgba(200,146,42,0.2);
    background: rgba(10,10,20,0.5);
    margin-bottom: 20px;
  }

  .word-builder-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 10px 16px;
    border-bottom: 1px solid var(--row-border);
    direction: ltr;
    flex-wrap: wrap;
    gap: 6px;
  }

  .word-builder-label {
    font-family: 'Cinzel', serif;
    font-size: 10px;
    letter-spacing: 0.3em;
    color: var(--amber);
    text-transform: uppercase;
  }

  .word-builder-glyphs {
    font-family: 'Noto Sans Hebrew', sans-serif;
    font-size: 22px;
    color: var(--amber-bright);
    direction: rtl;
    text-shadow: 0 0 14px rgba(200,146,42,0.35);
    min-width: 32px;
    text-align: right;
  }

  .word-builder-dim {
    font-size: 10px;
    letter-spacing: 0.2em;
    color: var(--amber-dim);
    direction: ltr;
  }

  /* GLYPH ROWS */
  .substrate-stack { display: flex; flex-direction: column; }

  .substrate-row { animation: rowReveal 0.4s ease forwards; opacity: 0; }

  @keyframes rowReveal {
    from { opacity: 0; transform: translateY(-6px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .row-label {
    font-size: 9px;
    letter-spacing: 0.3em;
    color: var(--amber-dim);
    text-align: center;
    padding: 8px 0 4px;
    text-transform: uppercase;
    direction: ltr;
  }

  .row-label.active-label { color: var(--amber); }

  .glyph-row {
    display: flex;
    flex-direction: row-reverse;
    gap: 3px;
    overflow-x: auto;
    padding: 6px 8px 10px;
    scrollbar-width: thin;
    scrollbar-color: var(--amber-dim) transparent;
    border-bottom: 1px solid rgba(200,146,42,0.06);
  }

  .glyph-row::-webkit-scrollbar { height: 2px; }
  .glyph-row::-webkit-scrollbar-thumb { background: var(--amber-dim); }

  .glyph-btn {
    flex-shrink: 0;
    width: var(--glyph-size);
    height: var(--glyph-size);
    background: transparent;
    border: 1px solid rgba(200,146,42,0.18);
    border-radius: 3px;
    color: var(--white);
    font-family: 'Noto Sans Hebrew', sans-serif;
    font-size: 21px;
    cursor: pointer;
    transition: all 0.18s ease;
    display: flex; align-items: center; justify-content: center;
  }

  .glyph-btn:hover:not(:disabled) {
    border-color: var(--amber);
    color: var(--amber-bright);
    background: rgba(200,146,42,0.08);
    transform: translateY(-2px);
  }

  .glyph-btn.selected {
    border-color: var(--amber-bright);
    background: rgba(200,146,42,0.18);
    color: var(--amber-bright);
    box-shadow: 0 0 10px rgba(200,146,42,0.28);
  }

  .glyph-btn:disabled:not(.selected) { opacity: 0.15; cursor: default; }

  /* WORD CONTROLS */
  .word-controls {
    display: flex;
    gap: 8px;
    padding: 10px 16px;
    direction: ltr;
    flex-wrap: wrap;
  }

  .ctrl-btn {
    background: transparent;
    border: 1px solid var(--dim);
    color: var(--dim);
    font-family: 'Share Tech Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.18em;
    padding: 6px 16px;
    cursor: pointer;
    text-transform: uppercase;
    transition: all 0.2s;
  }

  .ctrl-btn:hover { border-color: var(--amber); color: var(--amber); }
  .ctrl-btn.primary { border-color: var(--amber-dim); color: var(--amber); }
  .ctrl-btn.primary:hover { border-color: var(--amber-bright); background: rgba(200,146,42,0.08); }
  .ctrl-btn.commit { border-color: rgba(100,180,100,0.3); color: rgba(140,210,140,0.7); }
  .ctrl-btn.commit:hover { border-color: rgba(100,200,100,0.6); color: rgba(160,230,160,0.9); background: rgba(100,180,100,0.06); }

  /* SENTENCE CONTROLS */
  .sentence-controls {
    display: flex;
    gap: 8px;
    justify-content: center;
    padding: 0 0 24px;
    flex-wrap: wrap;
  }

  /* WORD RESONANCE (inline per word) */
  .word-resonance-inline {
    padding: 12px 16px;
    border-top: 1px solid rgba(200,146,42,0.08);
    background: rgba(200,146,42,0.03);
    direction: ltr;
    display: none;
  }

  .word-resonance-inline.visible { display: block; }

  .wri-phonetic {
    font-size: 14px;
    color: rgba(232,228,217,0.7);
    margin-bottom: 4px;
    letter-spacing: 0.1em;
  }

  .wri-phonetic .ph-ipa { font-size: 11px; color: var(--amber-dim); margin-left: 8px; }

  .wri-approx {
    font-size: 16px;
    color: var(--amber-bright);
    margin-bottom: 10px;
  }

  .wri-approx .approx-symbol { color: var(--amber-dim); font-size: 12px; margin-right: 4px; }
  .wri-approx .approx-note { font-size: 9px; letter-spacing: 0.2em; color: var(--dim); margin-left: 8px; text-transform: uppercase; vertical-align: middle; }

  .wri-def {
    font-size: 11.5px;
    line-height: 1.8;
    color: rgba(232,228,217,0.75);
    border-left: 2px solid var(--amber-dim);
    padding-left: 12px;
    white-space: pre-wrap;
    margin-bottom: 10px;
  }

  .wri-axes { display: flex; flex-wrap: wrap; gap: 5px; }

  /* SENTENCE RESONANCE PANEL */
  .sentence-panel {
    border: 1px solid rgba(200,146,42,0.25);
    background: rgba(10,10,15,0.9);
    display: none;
    margin-top: 8px;
  }

  .sentence-panel.visible { display: block; animation: rowReveal 0.5s ease forwards; }

  .sentence-panel-header {
    padding: 14px 20px;
    border-bottom: 1px solid var(--row-border);
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 8px;
    direction: ltr;
  }

  .sp-title {
    font-family: 'Cinzel', serif;
    font-size: 12px;
    letter-spacing: 0.25em;
    color: var(--amber);
    text-transform: uppercase;
  }

  .sp-tag { font-size: 10px; letter-spacing: 0.18em; color: var(--amber-dim); }

  /* SENTENCE PHONETIC DISPLAY */
  .sentence-phonetic-block {
    padding: 18px 22px 14px;
    border-bottom: 1px solid rgba(200,146,42,0.1);
    background: rgba(200,146,42,0.03);
    direction: ltr;
  }

  .sp-section-label {
    font-size: 9px;
    letter-spacing: 0.28em;
    color: var(--dim);
    text-transform: uppercase;
    margin-bottom: 8px;
  }

  .sentence-full-hebrew {
    font-family: 'Noto Sans Hebrew', sans-serif;
    font-size: clamp(22px, 5vw, 36px);
    color: var(--amber-bright);
    direction: rtl;
    text-shadow: 0 0 18px rgba(200,146,42,0.35);
    letter-spacing: 0.1em;
    margin-bottom: 10px;
    line-height: 1.4;
  }

  .sentence-romanized {
    font-size: 17px;
    color: rgba(232,228,217,0.85);
    letter-spacing: 0.1em;
    margin-bottom: 4px;
  }

  .sentence-ipa {
    font-size: 13px;
    color: var(--amber-dim);
    letter-spacing: 0.06em;
    margin-bottom: 10px;
  }

  .sentence-approx-block {
    font-size: 15px;
    color: var(--amber-bright);
    margin-top: 10px;
  }

  .sentence-approx-block .approx-symbol { color: var(--amber-dim); margin-right: 5px; font-size: 12px; }
  .sentence-approx-block .approx-note { font-size: 9px; letter-spacing: 0.2em; color: var(--dim); margin-left: 8px; text-transform: uppercase; vertical-align: middle; }

  .word-breakdown-row {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 12px;
    direction: ltr;
  }

  .word-breakdown-chip {
    display: flex;
    flex-direction: column;
    align-items: center;
    background: rgba(200,146,42,0.06);
    border: 1px solid rgba(200,146,42,0.15);
    border-radius: 3px;
    padding: 6px 12px;
    gap: 2px;
    min-width: 60px;
  }

  .wbc-hebrew {
    font-family: 'Noto Sans Hebrew', sans-serif;
    font-size: 18px;
    color: var(--amber-bright);
    direction: rtl;
  }

  .wbc-roman { font-size: 11px; color: rgba(232,228,217,0.6); letter-spacing: 0.08em; }
  .wbc-approx { font-size: 10px; color: var(--amber-dim); font-style: italic; }

  /* SENTENCE DOMAIN RESONANCE */
  .sentence-domain-block {
    padding: 14px 20px;
    border-bottom: 1px solid rgba(200,146,42,0.06);
    direction: ltr;
  }

  .sentence-domain-block:last-child { border-bottom: none; }

  .domain-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 8px;
  }

  .domain-name {
    font-family: 'Cinzel', serif;
    font-size: 10px;
    letter-spacing: 0.2em;
    color: var(--amber);
    text-transform: uppercase;
  }

  .density-bar-wrap { display: flex; align-items: center; gap: 8px; }
  .density-bar { width: 80px; height: 3px; background: rgba(200,146,42,0.1); border-radius: 2px; overflow: hidden; }
  .density-fill { height: 100%; background: var(--amber); border-radius: 2px; transition: width 0.6s ease; }
  .density-pct { font-size: 10px; color: var(--amber-dim); min-width: 28px; }

  .domain-section-label {
    font-size: 9px;
    letter-spacing: 0.22em;
    color: var(--dim);
    text-transform: uppercase;
    margin-bottom: 3px;
  }

  .term-list { font-size: 11px; line-height: 1.7; color: rgba(232,228,217,0.6); margin-bottom: 8px; }
  .term-list.intersection-terms { color: var(--amber-bright); }

  .term-pill {
    display: inline-block;
    background: rgba(200,146,42,0.1);
    border: 1px solid rgba(200,146,42,0.28);
    border-radius: 2px;
    padding: 1px 6px;
    margin: 2px 2px;
    font-size: 10px;
    color: var(--amber-bright);
  }

  .term-pill.union-pill {
    background: transparent;
    border-color: rgba(200,146,42,0.1);
    color: rgba(232,228,217,0.4);
  }

  .empty-msg { font-size: 10px; color: var(--dim); font-style: italic; }

  /* AXIS CHIPS */
  .axis-chip {
    font-size: 9px;
    letter-spacing: 0.15em;
    color: var(--amber-dim);
    border: 1px solid rgba(200,146,42,0.12);
    padding: 1px 7px;
    border-radius: 2px;
    text-transform: uppercase;
  }

  .axis-chip.resonant {
    color: var(--amber);
    border-color: rgba(200,146,42,0.38);
    background: rgba(200,146,42,0.07);
  }

  .footer {
    text-align: center;
    padding: 40px 0 20px;
    font-size: 10px;
    letter-spacing: 0.25em;
    color: var(--dim);
    direction: ltr;
  }

  * { scrollbar-width: thin; scrollbar-color: var(--amber-dim) transparent; }
</style>
</head>
<body>
<div class="container">

  <div class="header">
    <div class="header-title">Mashet Sentence Engine</div>
    <div class="header-formula" dir="ltr">
      [(<span>א</span>–<span>ת</span>)<sup>n</sup>]
      + [(<span>א</span>–<span>ת</span>)<sup>n</sup>]
      + [(<span>א</span>–<span>ת</span>)<sup>n</sup>]
      + …
    </div>
  </div>

  <!-- SENTENCE BAR -->
  <div class="sentence-bar" id="sentenceBar">
    <div class="sentence-bar-label">sentence composition</div>
    <div class="sentence-empty" id="sentenceEmpty">— build your first word below —</div>
  </div>

  <!-- ACTIVE WORD BUILDER -->
  <div class="word-builder" id="wordBuilder">
    <div class="word-builder-header">
      <div class="word-builder-label" id="wbLabel">Word 1</div>
      <div class="word-builder-glyphs" id="wbGlyphs">—</div>
      <div class="word-builder-dim" id="wbDim">— select a glyph —</div>
    </div>
    <div class="substrate-stack" id="substrateStack"></div>
    <div class="word-controls">
      <button class="ctrl-btn" onclick="wbUndo()">← Undo</button>
      <button class="ctrl-btn primary" onclick="wbResolve()">Resolve Word</button>
      <button class="ctrl-btn commit" onclick="wbCommit()">+ Commit Word →</button>
      <button class="ctrl-btn" onclick="wbClear()">Clear</button>
    </div>
    <div class="word-resonance-inline" id="wordResonanceInline"></div>
  </div>

  <!-- SENTENCE CONTROLS -->
  <div class="sentence-controls">
    <button class="ctrl-btn primary" onclick="resolveSentence()" id="btnResolveSentence" disabled>⬡ Resolve Sentence</button>
    <button class="ctrl-btn" onclick="resetAll()">Reset All</button>
  </div>

  <!-- SENTENCE RESONANCE PANEL -->
  <div class="sentence-panel" id="sentencePanel">
    <div class="sentence-panel-header">
      <div class="sp-title">Sentence Resonance Readout</div>
      <div class="sp-tag" id="spTag"></div>
    </div>
    <div class="sentence-phonetic-block" id="sentencePhoneticBlock"></div>
    <div id="sentenceDomainBody"></div>
  </div>

  <div class="footer">MASHET · SENTENCE ENGINE · (א–ת)ⁿ × W · SUBSTRATE LAYER</div>
</div>

<script>
// ═══════════════════════════════════════════════════════════════════
//  MASHET SUBSTRATE DATA
// ═══════════════════════════════════════════════════════════════════
const MASHET = {
  "א": {"Grammar":["Noun","Pronoun","Subject","Agent","Singular","Masculine","Abstract"],"Elemental":["Air","Water"],"Math":["Addition","Identity","Sequence","Unity","Beginning","Cardinal","Point","Increment","Function","Sum","Set","Variable","Prime","Factor","Count","Ratio","Zero","Placeholder","Operator","Parentheses","Exponent","Root","Coefficient","Element","Interval"],"Science":["Energy","Force","Particle","Wave","Potential","Quantum","Field","Mass","Gravity","Motion","Light","Charge","Atom","Proton","Neutron","Electron","Spectrum","Oscillation","Spin","Momentum","Conservation","Vector","Radiation","Frequency","Entropy"],"Corporeal":["Head","Brain","Eyes","Ears","Breath","Face","Mouth","Tongue","Nose","Skull","Neck","Spine","Expression","Jaw","Forehead","Thought","Vision","Perception","Hearing","Speech","Cognitive","Sensory","Awareness","Pulse","Mind"],"Emotional":["Joy","Curiosity","Wonder","Awe","Excitement","Optimism","Anticipation","Motivation","Inspiration","Hope","Confidence","Playfulness","Enthusiasm","Delight","Interest","Creativity","Surprise","Engagement","Alertness","Energy","Passion","Aliveness","Reflection","Insight"]},
  "ב": {"Grammar":["Noun","Object","Complement","Preposition","Singular","Feminine","Concrete"],"Elemental":["Water","Earth"],"Math":["Subtraction","Difference","Boundary","Containment","Ratio","Area","Segment","Fraction","Division","Set","Vector","Constant","Multiplier","Base","Function","Complement","Interval","Bound","Modulus","Limit","Sum","Sequence","Coefficient","Zero","Operator"],"Science":["Molecule","Solution","Fluid","Flow","Density","Pressure","Buoyancy","Volume","Mass","Force","Energy","Atom","Reaction","Diffusion","Membrane","Ion","Concentration","Gravity","Cycle","Current","Heat","Conductivity","Magnetism","Charge","Entropy"],"Corporeal":["Chest","Heart","Lungs","Ribcage","Circulation","Breathing","Sternum","Upper Body","Throat","Voice","Oxygenation","Heartbeat","Pulse","Emotion","Expression","Strength","Protection","Vitality","Thorax","Breath","Sensory","Motion","Support","Posture"],"Emotional":["Nurturance","Compassion","Care","Safety","Protection","Comfort","Love","Attachment","Empathy","Affection","Warmth","Stability","Security","Gratitude","Devotion","Trust","Patience","Tolerance","Tenderness","Contentment","Harmony","Calm","Support","Relief","Reassurance"]},
  "ג": {"Grammar":["Verb","Transitive","Active","Predicate","Past","Third Person"],"Elemental":["Fire","Air"],"Math":["Multiplication","Product","Factor","Coefficient","Ratio","Power","Function","Exponent","Operator","Sum","Segment","Increment","Set","Vector","Bound","Base","Derivative","Function Composition","Interval","Cardinality","Permutation","Combination","Modulus","Root","Difference"],"Science":["Combustion","Heat","Fire","Energy","Reaction","Plasma","Temperature","Force","Acceleration","Pressure","Radiation","Velocity","Momentum","Mass","Wave","Photon","Electron","Neutron","Particle","Friction","Work","Power","Field","Vector","Oscillation"],"Corporeal":["Arms","Hands","Fingers","Grasping","Action","Manipulation","Dexterity","Strength","Motion","Reach","Flexion","Extension","Gesture","Pressure","Tool Use","Grip","Coordination","Energy","Force","Movement","Contact","Interaction","Push","Pull","Extension"],"Emotional":["Action","Drive","Ambition","Assertiveness","Initiative","Determination","Courage","Boldness","Energy","Motivation","Confidence","Adventure","Leadership","Willpower","Risk-taking","Challenge","Enthusiasm","Passion","Focus","Strength","Engagement","Force","Dynamism"]},
  "ד": {"Grammar":["Verb","Intransitive","Auxiliary","Mood: Indicative","Future","Second Person"],"Elemental":["Earth","Water"],"Math":["Division","Quotient","Fraction","Modulus","Ratio","Function","Limit","Sum","Product","Segment","Increment","Base","Operator","Interval","Set","Bound","Cardinality","Difference","Coefficient","Root","Derivative","Permutation","Complement","Element","Exponent"],"Science":["Solid","Structure","Density","Pressure","Mass","Volume","Force","Gravity","Molecule","Atom","Crystal","Tension","Stress","Friction","Inertia","Stability","Torque","Energy","Heat","Conductivity","Motion","Vector","Oscillation","Wave","Frequency"],"Corporeal":["Legs","Feet","Toes","Walking","Running","Support","Stability","Balance","Standing","Flexion","Extension","Grounding","Motion","Endurance","Strength","Posture","Gait","Propulsion","Locomotion","Agility","Pressure","Contact","Weight","Base"],"Emotional":["Patience","Endurance","Resilience","Stability","Responsibility","Persistence","Reliability","Discipline","Composure","Practicality","Groundedness","Acceptance","Tolerance","Perseverance","Fortitude","Steadfastness","Trustworthiness","Care","Diligence","Planning","Prudence","Order","Structure","Support"]},
