//  ENGLISH APPROXIMATION
// ═══════════════════════════════════════════════════════════════════
const GLYPH_CORES = {
  'א':{ primary:'origin',       alts:['breath','being','first']         },
  'ב':{ primary:'house',        alts:['container','interior','dwelling'] },
  'ג':{ primary:'lifting',      alts:['pride','stride','carrying']       },
  'ד':{ primary:'door',         alts:['threshold','passage','opening']   },
  'ה':{ primary:'breath',       alts:['revelation','the','presence']     },
  'ו':{ primary:'hook',         alts:['connection','and','joining']      },
  'ז':{ primary:'weapon',       alts:['cutting','edge','arrow']          },
  'ח':{ primary:'fence',        alts:['boundary','enclosure','protection']},
  'ט':{ primary:'coil',         alts:['surround','basket','vessel']      },
  'י':{ primary:'hand',         alts:['deed','point','work']             },
  'כ':{ primary:'palm',         alts:['capacity','cupping','holding']    },
  'ל':{ primary:'staff',        alts:['learning','toward','aspiration']  },
  'מ':{ primary:'water',        alts:['flow','source','depth']           },
  'נ':{ primary:'fish',         alts:['emergence','motion','life']       },
  'ס':{ primary:'support',      alts:['prop','cycle','surrounding']      },
  'ע':{ primary:'eye',          alts:['sight','source','well']           },
  'פ':{ primary:'mouth',        alts:['speech','opening','expression']   },
  'צ':{ primary:'hook',         alts:['righteousness','pull','intent']   },
  'ק':{ primary:'back of head', alts:['cycle','sun','behind']            },
  'ר':{ primary:'head',         alts:['chief','beginning','person']      },
  'ש':{ primary:'teeth',        alts:['fire','sharp','consume']          },
  'ת':{ primary:'mark',         alts:['seal','covenant','completion']    }
};

const DOMAIN_WEIGHT = { Emotional:1.6, Corporeal:1.4, Science:1.0, Math:0.8, Grammar:0.6, Elemental:1.2 };

function inferEnglishApprox(glyphs, domainData) {
  if (glyphs.length===1) {
    const c=GLYPH_CORES[glyphs[0]]; return c?[c.primary,...c.alts.slice(0,2)]:[glyphs[0]];
  }
  const scores={};
  domainData.forEach(d=>{
    const w=DOMAIN_WEIGHT[d.domain]||1;
    d.intersection.forEach(t=>{scores[t]=(scores[t]||0)+w*2;});
    d.union.forEach(t=>{scores[t]=(scores[t]||0)+w*0.3;});
  });
  glyphs.forEach(g=>{
    const c=GLYPH_CORES[g]; if(!c) return;
    scores[c.primary]=(scores[c.primary]||0)+3;
    c.alts.forEach(a=>{scores[a]=(scores[a]||0)+1.5;});
  });
  const ranked=Object.entries(scores).sort((a,b)=>b[1]-a[1])
    .map(([t])=>t.toLowerCase()).filter(t=>t.length<=18&&!t.includes(':')&&!t.includes('('));
  const seen=new Set(), top=[];
  for(const t of ranked){
    const base=t.replace(/s$/,'').replace(/ing$/,'').replace(/ion$/,'');
    if(!seen.has(base)){seen.add(base);top.push(t);}
    if(top.length>=3) break;
  }
  return top.length?top:['undefined'];
}

// ═══════════════════════════════════════════════════════════════════
//  DOMAIN INTERSECTION ENGINE
// ═══════════════════════════════════════════════════════════════════
function computeWordDomains(glyphs) {
  return DOMAINS.map(domain=>{
    const arrays = glyphs.map(g=>MASHET[g][domain]||[]);
    let intersection = arrays[0]?[...arrays[0]]:[];
    arrays.slice(1).forEach(arr=>{intersection=intersection.filter(t=>arr.includes(t));});
    const union = [...new Set(arrays.flat())];
    const pct = Math.round(union.length>0?intersection.length/union.length*100:0);
    return {domain,intersection,union,pct};
  });
}

// Sentence-level: intersect across ALL words' union fields per domain
function computeSentenceDomains(words) {
  return DOMAINS.map(domain=>{
    // Each word contributes its full domain union
    const wordFields = words.map(w=>{
      const d=w.domainData.find(d=>d.domain===domain);
      return d?d.union:[];
    });
    let intersection=[...wordFields[0]||[]];
    wordFields.slice(1).forEach(f=>{intersection=intersection.filter(t=>f.includes(t));});
    const union=[...new Set(wordFields.flat())];
    const pct=Math.round(union.length>0?intersection.length/union.length*100:0);
    return {domain,intersection,union,pct};
  });
}

// ═══════════════════════════════════════════════════════════════════
//  ROW BUILDER
// ═══════════════════════════════════════════════════════════════════
function toSuperscript(n){
  const s=['⁰','¹','²','³','⁴','⁵','⁶','⁷','⁸','⁹'];
  return String(n).split('').map(d=>s[parseInt(d)]).join('');
}

function buildRow(rowIndex){
  const row=document.createElement('div');
  row.className='substrate-row'; row.id=`row-${rowIndex}`;
  const label=document.createElement('div');
  label.className=`row-label ${rowIndex===0?'active-label':''}`;
  label.textContent=`(א–ת)${toSuperscript(rowIndex+1)}`;
  row.appendChild(label);
  const gr=document.createElement('div'); gr.className='glyph-row';
  GLYPHS.forEach(g=>{
    const btn=document.createElement('button');
    btn.className='glyph-btn'; btn.textContent=g;
    btn.onclick=()=>wbSelectGlyph(g,rowIndex,btn);
    gr.appendChild(btn);
  });
  row.appendChild(gr);
  return row;
}

// ═══════════════════════════════════════════════════════════════════
//  WORD BUILDER LOGIC
// ═══════════════════════════════════════════════════════════════════
function wbSelectGlyph(glyph,rowIndex,btn){
  const row=document.getElementById(`row-${rowIndex}`);
  row.querySelectorAll('.glyph-btn').forEach(b=>{b.classList.remove('selected');b.disabled=(b!==btn);});
  btn.classList.add('selected');
  activeGlyphs[rowIndex]=glyph;
  if(rowIndex<activeGlyphs.length-1){
    activeGlyphs=activeGlyphs.slice(0,rowIndex+1);
    let nr=document.getElementById(`row-${rowIndex+1}`);
    while(nr){nr.remove();nr=document.getElementById(`row-${rowIndex+1}`);}
  }
  updateWBDisplay();
  document.getElementById('substrateStack').appendChild(buildRow(rowIndex+1));
  document.getElementById('wordResonanceInline').classList.remove('visible');
}

function updateWBDisplay(){
  const n=activeGlyphs.length;
  document.getElementById('wbGlyphs').textContent=n?activeGlyphs.join(''):'—';
  document.getElementById('wbLabel').textContent=`Word ${committedWords.length+1}`;
  document.getElementById('wbDim').textContent=n?`(א–ת)${toSuperscript(n)} · ${n} glyph${n>1?'s':''}`:
    '— select a glyph —';
}

function wbUndo(){
  if(!activeGlyphs.length) return;
  const last=activeGlyphs.length; const prev=last-1;
  const er=document.getElementById(`row-${last}`); if(er) er.remove();
  const pr=document.getElementById(`row-${prev}`);
  if(pr) pr.querySelectorAll('.glyph-btn').forEach(b=>{b.disabled=false;b.classList.remove('selected');});
  activeGlyphs.pop();
  updateWBDisplay();
  document.getElementById('wordResonanceInline').classList.remove('visible');
}

function wbClear(){
  activeGlyphs=[];
  const stack=document.getElementById('substrateStack');
  stack.innerHTML=''; stack.appendChild(buildRow(0));
  updateWBDisplay();
  document.getElementById('wordResonanceInline').classList.remove('visible');
}

function wbResolve(){
  if(!activeGlyphs.length) return;
  const domainData=computeWordDomains(activeGlyphs);
  renderWordResonanceInline([...activeGlyphs],domainData);
}

function renderWordResonanceInline(glyphs,domainData){
  const panel=document.getElementById('wordResonanceInline');
  const phon=buildPronunciation(glyphs);
  const approx=inferEnglishApprox(glyphs,domainData);

  // Build type sig (simple)
  const gramD=domainData.find(d=>d.domain==='Grammar');
  const gramTerms=gramD?(gramD.intersection.length?gramD.intersection:gramD.union.slice(0,3)):[];
  const roles={'Noun':'NOMINAL','Verb':'OPERATIVE','Adjective':'QUALITATIVE','Preposition':'RELATIONAL',
    'Conjunction':'CONNECTIVE','Article':'DEFINITE-MARKER','Pronoun':'PRONOMINAL'};
  let role='SUBSTRATE';
  for(const [k,v] of Object.entries(roles)){if(gramTerms.includes(k)){role=v;break;}}
  const emoD=domainData.find(d=>d.domain==='Emotional');
  const emoTop=(emoD?.intersection.length?emoD.intersection:emoD?.union||[]).slice(0,2);
  const typeSig=`[ ${role} :: ${emoTop.map(t=>t.toLowerCase()).join(', ')||'—'} ]`;

  // Resonant axes
  const axes=domainData.map(d=>
    `<span class="axis-chip${d.intersection.length?' resonant':''}">${d.domain}</span>`
  ).join('');

  panel.innerHTML=`
    ${phon?`<div class="wri-phonetic">
      ${phon.romanized} <span class="ph-ipa">${phon.ipa}</span>
      <span style="font-size:9px;letter-spacing:.2em;color:var(--dim);margin-left:8px;text-transform:uppercase">${phon.letters}</span>
    </div>`:''}
    <div class="wri-approx">
      <span class="approx-symbol">≈</span><strong>${approx[0]}</strong>${approx.slice(1).map(w=>` / ${w}`).join('')}<span class="approx-note">eng. approx.</span>
    </div>
    <div class="wri-def">${typeSig}</div>
    <div class="wri-axes">${axes}</div>`;
  panel.classList.add('visible');
}

function wbCommit(){
  if(!activeGlyphs.length) return;
  const glyphs=[...activeGlyphs];
  const domainData=computeWordDomains(glyphs);
  const phon=buildPronunciation(glyphs);
  const approx=inferEnglishApprox(glyphs,domainData);

  committedWords.push({glyphs,domainData,phon,approx});
  renderSentenceBar();

  // Reset builder for next word
  activeGlyphs=[];
  const stack=document.getElementById('substrateStack');
  stack.innerHTML=''; stack.appendChild(buildRow(0));
  updateWBDisplay();
  document.getElementById('wordResonanceInline').classList.remove('visible');
  document.getElementById('sentencePanel').classList.remove('visible');

  // Enable sentence resolve if ≥2 words
  document.getElementById('btnResolveSentence').disabled=(committedWords.length<2);
}

// ═══════════════════════════════════════════════════════════════════
//  SENTENCE BAR
// ═══════════════════════════════════════════════════════════════════
function renderSentenceBar(){
  const bar=document.getElementById('sentenceBar');
  bar.innerHTML='<div class="sentence-bar-label">sentence composition</div>';
  if(!committedWords.length){
    bar.innerHTML+='<div class="sentence-empty" id="sentenceEmpty">— build your first word below —</div>';
    return;
  }
  committedWords.forEach((w,i)=>{
    const tok=document.createElement('div');
    tok.className='word-token';
    tok.innerHTML=`
      <span class="tok-hebrew">${w.glyphs.join('')}</span>
      <span class="tok-phonetic">${w.phon?.romanized||''}</span>
      <span class="tok-approx">${w.approx[0]||''}</span>
      <span class="tok-delete" onclick="deleteWord(${i},event)">✕</span>`;
    bar.appendChild(tok);
  });
  // Add-word button
  const addBtn=document.createElement('button');
  addBtn.className='word-add-btn';
  addBtn.textContent='+ word';
  addBtn.onclick=()=>{}; // builder is always open below
  bar.appendChild(addBtn);
}

function deleteWord(i,evt){
  evt.stopPropagation();
  committedWords.splice(i,1);
  renderSentenceBar();
  document.getElementById('sentencePanel').classList.remove('visible');
  document.getElementById('btnResolveSentence').disabled=(committedWords.length<2);
}

// ═══════════════════════════════════════════════════════════════════
//  SENTENCE RESONANCE
// ═══════════════════════════════════════════════════════════════════
function resolveSentence(){
  if(committedWords.length<2) return;

  const sentPanel=document.getElementById('sentencePanel');
  const spTag=document.getElementById('spTag');
  const phoneticBlock=document.getElementById('sentencePhoneticBlock');
  const domainBody=document.getElementById('sentenceDomainBody');

  const W=committedWords.length;
  spTag.textContent=`${W} words · ${committedWords.reduce((a,w)=>a+w.glyphs.length,0)} glyphs total`;

  // PHONETICS
  const sentPhon=buildSentencePronunciation(committedWords);
  const fullHebrew=committedWords.map(w=>w.glyphs.join('')).join(' ');

  // Word breakdown chips
  const chips=committedWords.map(w=>`
    <div class="word-breakdown-chip">
      <span class="wbc-hebrew">${w.glyphs.join('')}</span>
      <span class="wbc-roman">${w.phon?.romanized||''}</span>
      <span class="wbc-approx">${w.approx[0]||''}</span>
    </div>`).join('');

  // Sentence-level approx: merge all word approx terms
  const sentApproxTerms=[...new Set(committedWords.flatMap(w=>w.approx))].slice(0,4);

  phoneticBlock.innerHTML=`
    <div class="sp-section-label">Full Sentence</div>
    <div class="sentence-full-hebrew">${fullHebrew}</div>
    <div class="sentence-romanized">${sentPhon.romanized}</div>
    <div class="sentence-ipa">${sentPhon.ipa}</div>
    <div class="sentence-approx-block">
      <span class="approx-symbol">≈</span>
      <strong>${sentApproxTerms[0]||''}</strong>${sentApproxTerms.slice(1).map(t=>` / ${t}`).join('')}
      <span class="approx-note">sentence field approx.</span>
    </div>
    <div class="sp-section-label" style="margin-top:14px">Word Breakdown</div>
    <div class="word-breakdown-row">${chips}</div>`;

  // DOMAIN RESONANCE across sentence
  const sentDomains=computeSentenceDomains(committedWords);
  domainBody.innerHTML='';
  sentDomains.forEach(d=>{
    const block=document.createElement('div');
    block.className='sentence-domain-block';
    block.innerHTML=`
      <div class="domain-header">
        <div class="domain-name">${d.domain}</div>
        <div class="density-bar-wrap">
          <div class="density-bar"><div class="density-fill" style="width:${d.pct}%"></div></div>
          <div class="density-pct">${d.pct}%</div>
        </div>
      </div>
      <div class="domain-section-label">Sentence Resonance (shared across all ${W} words)</div>
      <div class="term-list intersection-terms">${d.intersection.length
        ?d.intersection.map(t=>`<span class="term-pill">${t}</span>`).join('')
        :'<span class="empty-msg">no shared terms across all words</span>'}</div>
      <div class="domain-section-label">Full Field (sentence union)</div>
      <div class="term-list">${d.union.map(t=>`<span class="term-pill union-pill">${t}</span>`).join('')}</div>`;
    domainBody.appendChild(block);
  });

  sentPanel.classList.add('visible');
  sentPanel.scrollIntoView({behavior:'smooth',block:'start'});
}

function resetAll(){
  committedWords=[];
  activeGlyphs=[];
  const stack=document.getElementById('substrateStack');
  stack.innerHTML=''; stack.appendChild(buildRow(0));
  updateWBDisplay();
  renderSentenceBar();
  document.getElementById('wordResonanceInline').classList.remove('visible');
  document.getElementById('sentencePanel').classList.remove('visible');
  document.getElementById('btnResolveSentence').disabled=true;
}

// ═══════════════════════════════════════════════════════════════════
//  INIT
// ═══════════════════════════════════════════════════════════════════
document.addEventListener('DOMContentLoaded',()=>{
  document.getElementById('substrateStack').appendChild(buildRow(0));
  renderSentenceBar();
});
</script>
</body>
</html>
