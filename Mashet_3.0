const GLYPHS  = ["א","ב","ג","ד","ה","ו","ז","ח","ט","י","כ","ל","מ","נ","ס","ע","פ","צ","ק","ר","ש","ת"];
const DOMAINS = ["Grammar","Elemental","Math","Science","Corporeal","Emotional"];

// ═══════════════════════════════════════════════════════════════════
//  STATE
// ═══════════════════════════════════════════════════════════════════
let committedWords = [];   // [{glyphs, domainData, phonetic, approx}]
let activeGlyphs   = [];   // current word being built

// ═══════════════════════════════════════════════════════════════════
//  PHONETICS
// ═══════════════════════════════════════════════════════════════════
const GLYPH_PHONETICS = {
  'א':{ roman:'',   ipa:'ʔ',  name:'alef'   },
  'ב':{ roman:'v',  ipa:'v',  name:'vet'    },
  'ג':{ roman:'g',  ipa:'ɡ',  name:'gimel'  },
  'ד':{ roman:'d',  ipa:'d',  name:'dalet'  },
  'ה':{ roman:'h',  ipa:'h',  name:'heh'    },
  'ו':{ roman:'v',  ipa:'v',  name:'vav'    },
  'ז':{ roman:'z',  ipa:'z',  name:'zayin'  },
  'ח':{ roman:'ch', ipa:'χ',  name:'chet'   },
  'ט':{ roman:'t',  ipa:'t',  name:'tet'    },
  'י':{ roman:'y',  ipa:'j',  name:'yod'    },
  'כ':{ roman:'ch', ipa:'χ',  name:'chaf'   },
  'ל':{ roman:'l',  ipa:'l',  name:'lamed'  },
  'מ':{ roman:'m',  ipa:'m',  name:'mem'    },
  'נ':{ roman:'n',  ipa:'n',  name:'nun'    },
  'ס':{ roman:'s',  ipa:'s',  name:'samech' },
  'ע':{ roman:'',   ipa:'ʕ',  name:'ayin'   },
  'פ':{ roman:'f',  ipa:'f',  name:'feh'    },
  'צ':{ roman:'tz', ipa:'ts', name:'tzadi'  },
  'ק':{ roman:'k',  ipa:'k',  name:'kof'    },
  'ר':{ roman:'r',  ipa:'ʁ',  name:'resh'   },
  'ש':{ roman:'sh', ipa:'ʃ',  name:'shin'   },
  'ת':{ roman:'t',  ipa:'t',  name:'tav'    }
};

function buildPronunciation(glyphs) {
  if (!glyphs.length) return null;
  let roman='', ipa='';
  const vowel = 'a';
  for (let i=0; i<glyphs.length; i++) {
    const ph = GLYPH_PHONETICS[glyphs[i]]; if (!ph) continue;
    const isLast = i===glyphs.length-1;
    const isSilent = ph.roman==='';
    if (!isSilent) {
      roman+=ph.roman; ipa+=ph.ipa;
      if (!isLast) {
        const nph = GLYPH_PHONETICS[glyphs[i+1]];
        if (!nph || nph.roman!=='') { roman+=vowel; ipa+='a'; }
      }
    } else {
      if (i===0 && i<glyphs.length-1) { roman+=vowel; ipa+='a'; }
    }
  }
  roman = roman.replace(/aa/g,'a').replace(/([aeiou])\1/g,'$1');
  ipa   = ipa.replace(/aa/g,'a').replace(/([aeiouæœɪʏʊɛɔə])\1/g,'$1');
  const lvi = roman.search(/[aeiou][^aeiou]*$/);
  const stressed = lvi!==-1 ? roman.slice(0,lvi)+'ˈ'+roman.slice(lvi) : roman;
  return {
    romanized: stressed||roman,
    ipa: '/'+ipa+'/',
    letters: glyphs.map(g=>GLYPH_PHONETICS[g]?.name||g).join('-')
  };
}

// Sentence-level: words separated by spaces
function buildSentencePronunciation(words) {
  const parts = words.map(w => buildPronunciation(w.glyphs));
  return {
    romanized: parts.map(p=>p?.romanized||'?').join('  '),
    ipa: parts.map(p=>p?.ipa||'/?/').join('  ')
  };
}

